# Copy this file to .env. Never commit the populated .env file.
DWS_CHAT_AGENT_MODE=shadow
DWS_CHAT_AGENT_SELF_NAME=Your Name
DWS_CHAT_AGENT_SELF_OPEN_ID=your-open-dingtalk-id
DWS_CHAT_AGENT_CONTACTS_JSON=[{"alias":"teammate","display_name":"Teammate","user_id":"user-id","open_dingtalk_id":"open-dingtalk-id"}]
DWS_CHAT_AGENT_WORKSPACE_ROOT=/absolute/path/to/workspace
DWS_CHAT_AGENT_WORKTREE_ROOT=/absolute/path/to/workspace/.worktrees/dws-chat-agent
DWS_CHAT_AGENT_CODEX_BINARY=codex
DWS_CHAT_AGENT_WRITABLE_ROOTS_JSON=[]
DWS_CHAT_AGENT_EXECUTION_DOMAINS_JSON=[]
DWS_CHAT_AGENT_DWS_PROFILE=null
